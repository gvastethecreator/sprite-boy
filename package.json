{
  "name": "sprite-boy",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "protobufjs": "7.6.5",
    "undici": "7.28.0",
    "ws": "8.21.1"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && oxlint .",
    "clean": "rimraf dist logs",
    "build:log": "node scripts/log-runner.mjs build \"vite build\"",
    "test:log": "node scripts/log-runner.mjs test \"vitest run\"",
    "lint:log": "node scripts/log-runner.mjs lint \"oxlint .\""
  },
  "dependencies": {
    "@fontsource/archivo": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@google/genai": "^1.52.0",
    "@gsap/react": "^2.1.2",
    "gifshot": "^0.4.5",
    "gsap": "^3.15.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^29.1.1",
    "oxlint": "^1.73.0",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.2",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
