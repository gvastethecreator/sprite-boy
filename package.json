{
  "name": "sprite-boy",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && oxlint .",
    "clean": "rimraf dist logs",
    "build:log": "node scripts/log-runner.mjs build \"vite build\"",
    "test:log": "node scripts/log-runner.mjs test \"vitest run\"",
    "lint:log": "node scripts/log-runner.mjs lint \"oxlint .\""
  },
  "dependencies": {
    "@google/genai": "^1.31.0",
    "gifshot": "^0.4.5",
    "gsap": "^3.12.7",
    "jszip": "^3.10.1",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^26.1.0",
    "oxlint": "^1.56.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}